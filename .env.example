APP_NAME="Hospital Service Dashboard"
APP_ENV=production
APP_DEBUG=0
APP_TIMEZONE=Asia/Bangkok
APP_BASE_URL=https://example.go.th/dashboard
APP_MAX_DATE_RANGE_DAYS=370
APP_DEMO_MODE=0

# Security
APP_FORCE_HTTPS=1
APP_HSTS_ENABLED=1
APP_HSTS_MAX_AGE=31536000
APP_SESSION_NAME=HSDSESSID
APP_SESSION_SECURE_COOKIE=1
APP_ALLOWED_IPS=
APP_TRUSTED_PROXIES=127.0.0.1,::1
APP_CSP_ENABLED=1
APP_X_FRAME_OPTIONS=SAMEORIGIN
APP_REFERRER_POLICY=strict-origin-when-cross-origin
APP_PERMISSIONS_POLICY="geolocation=(), microphone=(), camera=()"
APP_CACHE_CONTROL_API="no-store, no-cache, must-revalidate, max-age=0"

# Audit / export
AUDIT_LOG_DB=1
AUDIT_LOG_FILE=1
APP_EXPORT_ROW_LIMIT=50000

# Dashboard database (target schema)
DB_DASHBOARD_HOST=127.0.0.1
DB_DASHBOARD_PORT=3306
DB_DASHBOARD_NAME=hos_dashboard
DB_DASHBOARD_CHARSET=utf8mb4
DB_DASHBOARD_USER=dashboard_user
DB_DASHBOARD_PASS="CHANGE_ME"
DB_DASHBOARD_TIMEOUT=5

# Source database (HOSxP)
DB_SOURCE_HOST=127.0.0.1
DB_SOURCE_PORT=3306
DB_SOURCE_NAME=hosxp
DB_SOURCE_CHARSET=utf8mb4
DB_SOURCE_USER=hosxp_readonly
DB_SOURCE_PASS="CHANGE_ME"
DB_SOURCE_TIMEOUT=5

# ETL notification (optional)
ETL_FAIL_WEBHOOK_URL=
ETL_ALERT_COOLDOWN_MINUTES=30
